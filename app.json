      "requestHeaders": {
        "expo-channel-name": "production"
      }
    },
    "android": {
      "softwareKeyboardLayoutMode": "pan",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#15754E"
      },
      "package": "com.haritabhgupta.badmintoncourtsimulator",
      "versionCode": 20,
      "permissions": ["com.android.vending.BILLING"],
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "https",
              "host": "badmlabs.github.io",
              "pathPrefix": "/court/import"
            },
            {
              "scheme": "https",
              "host": "badmlabs.github.io",
              "pathPrefix": "/i"
            }
          ],
          "category": ["BROWSABLE", "DEFAULT"]
        }
      ]
    },
    "web": {
      "favicon": "./assets/logo.png"
    },
    "extra": {
      "eas": {
        "projectId": "3107f01f-e992-46de-8474-423ef400912f"
      }
    }
  }
